# =============================================================================
# AI AZURE PLATFORM - Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Variables marked as (REQUIRED) must be set for the application to work
# Variables marked as (OPTIONAL) have default values

# =============================================================================
# Azure Cosmos DB Configuration (REQUIRED)
# =============================================================================
# Azure Cosmos DB NoSQL API endpoint
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/

# Azure Cosmos DB primary key
COSMOS_KEY=your-cosmos-primary-key

# Database name (OPTIONAL - default: ai-platform)
COSMOS_DATABASE=ai-platform

# Container name (OPTIONAL - default: documents)
# Single container stores both documents and tasks, partitioned by domain_id
COSMOS_CONTAINER=documents

# Evaluation container name (OPTIONAL - default: evaluations)
# Stores evaluation runs and results, partitioned by pk (hybrid)
COSMOS_EVALUATION_CONTAINER=evaluations

# Conversations container name (OPTIONAL - default: conversations)
# Stores chat history and feedback, partitioned by user_id
COSMOS_CONVERSATIONS_CONTAINER=conversations

# =============================================================================
# OpenAI / Azure OpenAI Configuration (REQUIRED)
# =============================================================================
# Provider selection: "azure" or "openai"
# If omitted, the app uses Azure when AZURE_OPENAI_ENDPOINT exists; otherwise OpenAI.
OPENAI_API_PROVIDER=azure

# Standard OpenAI configuration
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI configuration
# GPT-4 deployment name for chat and summarization
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure OpenAI endpoint URL
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/

# Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-azure-openai-key

# Embedding model deployment for vector search (OPTIONAL - default: text-embedding-ada-002)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# =============================================================================
# Azure Document Intelligence Configuration (REQUIRED)
# =============================================================================
# Azure Document Intelligence (Form Recognizer) endpoint
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence.cognitiveservices.azure.com/

# Azure Document Intelligence API key
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key

# =============================================================================
# Azure AI Search Configuration (REQUIRED)
# =============================================================================
# Azure AI Search (Cognitive Search) endpoint
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net

# Azure AI Search admin API key
AZURE_SEARCH_API_KEY=your-search-admin-key

# Search index name (OPTIONAL - default: documents-index)
AZURE_SEARCH_INDEX_NAME=documents-index

# =============================================================================
# Azure Blob Storage Configuration
# =============================================================================
# Storage type: "local" for local filesystem, "azure_blob" for Azure Blob Storage
# (OPTIONAL - default: local)
STORAGE_TYPE=local

# Azure Storage connection string (REQUIRED if STORAGE_TYPE=azure_blob)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-storage;AccountKey=your-key;EndpointSuffix=core.windows.net

# =============================================================================
# Document Processing Configuration (OPTIONAL)
# =============================================================================
# Enable advanced OCR processing (converts PDFs to images for better extraction)
# Default: false
ENABLE_ADVANCED_OCR=false

# Use GPT-4 Vision for analyzing complex images/diagrams in documents
# Default: false
USE_GPT_VISION_FOR_FIGURES=false

# Enable summary generation in GOLD stage
# Default: true
ENABLE_GOLD_SUMMARY=true

# Enable vector indexing in GOLD stage (sends to Azure AI Search)
# Default: true
ENABLE_GOLD_VECTORIZATION=true

# Context for document processing (used in summarization prompts)
# Default: empty
DEAL_CONTEXT=

# =============================================================================
# LibreOffice Configuration (OPTIONAL)
# =============================================================================
# Path to LibreOffice soffice executable for Office document conversion
# Used to convert DOCX, DOC, PPTX, PPT to PDF before processing
# Windows: C:\\Program Files\\LibreOffice\\program\\soffice.exe
# Linux/Docker: /usr/bin/soffice
# macOS: /Applications/LibreOffice.app/Contents/MacOS/soffice
LIBREOFFICE_PATH=/usr/bin/soffice

# =============================================================================
# Azure OpenAI Vision Configuration (OPTIONAL)
# =============================================================================
# Separate Azure OpenAI resource for Vision capabilities (if using different region)
# If not set, uses the main AZURE_OPENAI_* variables
# AZURE_EU2_OPENAI_SERVICE=https://your-vision-openai.openai.azure.com/
# AZURE_EU2_OPENAI_VISION_KEY=your-vision-api-key
# AZURE_EU2_OPENAI_VISION_DEPLOYMENT=gpt-4o

# GPT-4 Vision deployment name (OPTIONAL - can be same as AZURE_OPENAI_DEPLOYMENT)
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o
